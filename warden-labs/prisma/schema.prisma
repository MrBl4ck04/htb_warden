generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        String   @id @default(uuid())
  username  String   @unique
  email     String   @unique
  password  String
  avatar    String?
  bio       String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  completedMachines UserMachine[]
  certificationPaths UserCertPath[]
  streakData        UserStreak?
}

model Machine {
  id             String   @id @default(uuid())
  name           String   @unique
  ip             String
  os             String
  difficulty     String
  techniques     String[]
  certifications String[]
  createdAt      DateTime @default(now())

  completedBy UserMachine[]
  pathWeeks   PathWeekMachine[]
}

model UserMachine {
  id          String   @id @default(uuid())
  userId      String
  machineId   String
  completedAt DateTime @default(now())
  rating      Int?

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  machine Machine @relation(fields: [machineId], references: [id], onDelete: Cascade)

  @@unique([userId, machineId])
}

model CertificationPath {
  id             String @id @default(uuid())
  name           String @unique
  slug           String @unique
  description    String
  icon           String
  color          String
  totalWeeks     Int
  estimatedHours Int
  level          String

  weeks     PathWeek[]
  userPaths UserCertPath[]
}

model PathWeek {
  id          String @id @default(uuid())
  pathId      String
  weekNumber  Int
  title       String
  description String
  focus       String

  path     CertificationPath @relation(fields: [pathId], references: [id], onDelete: Cascade)
  machines PathWeekMachine[]

  @@unique([pathId, weekNumber])
}

model PathWeekMachine {
  id        String @id @default(uuid())
  weekId    String
  machineId String
  orderNum  Int

  week    PathWeek @relation(fields: [weekId], references: [id], onDelete: Cascade)
  machine Machine  @relation(fields: [machineId], references: [id], onDelete: Cascade)

  @@unique([weekId, machineId])
}

model UserCertPath {
  id          String    @id @default(uuid())
  userId      String
  pathId      String
  startedAt   DateTime  @default(now())
  completedAt DateTime?
  currentWeek Int       @default(1)

  user User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  path CertificationPath @relation(fields: [pathId], references: [id], onDelete: Cascade)

  @@unique([userId, pathId])
}

model UserStreak {
  id               String    @id @default(uuid())
  userId           String    @unique
  currentStreak    Int       @default(0)
  longestStreak    Int       @default(0)
  lastActivityDate DateTime?
  totalDaysActive  Int       @default(0)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}
